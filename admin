                const matchFileD = url.match(/\/d\/([a-zA-Z0-9_-]+)/);
                const matchUcId = url.match(/[?&]id=([a-zA-Z0-9_-]+)/);
                if (matchFileD && matchFileD[1]) {
                    id = matchFileD[1];
                } else if (matchUcId && matchUcId[1]) {
                    id = matchUcId[1];
                }
                if (id) {
                    return "https://lh3.googleusercontent.com/d/" + id;
