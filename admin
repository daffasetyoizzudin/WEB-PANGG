        async function previewAndCompressSettingImage(input, previewElementId, key) {
            const file = input.files[0];
            if (!file) return;

            const preview = document.getElementById(previewElementId);
            const originalSrc = preview.src;
            preview.src = "https://placehold.co/200?text=COMPRESSING...";

            try {
                // Konfigurasi ukuran optimal resolusi tinggi (Ultra Sharp)
                let width = 1600;
                let height = 1600;
                if (key === "Banner") {
                    width = 1920; // Banner Full HD sangat tajam dan stabil
                    height = 1080;
                }

                // Kompresi berkualitas tinggi 85% (Bebas buram dan piksel pecah)
                const compressedBase64 = await compressAndConvertToBase64(file, width, height, 0.85);
                preview.src = compressedBase64;
                
                // Simpan biner terkompresi ke penampung sementara
                settingsFilesBase64[key] = compressedBase64;
                showToast(`Gambar ${key} berhasil diproses dengan kualitas tinggi!`);
            } catch (err) {
                console.error("Gagal kompresi aset:", err);
                showToast("Gagal memproses file.");
                preview.src = originalSrc;
            }
        }

        async function saveStoreSettings(event) {
            event.preventDefault();

            const btn = document.getElementById("btnSaveSettings");
            btn.disabled = true;
            btn.innerHTML = `<span class="animate-spin rounded-full h-4 w-4 border-b-2 border-white mr-2"></span> MENYIMPAN...`;
            showLoader();

            const wa = document.getElementById("setWA").value.trim();
            const ig = document.getElementById("setIG").value.trim();
            const tik = document.getElementById("setTikTok").value.trim();
            const vouchers = document.getElementById("setVouchers").value.trim();
            
            const newAdminUser = document.getElementById("setAdminUser").value.trim();
            const newAdminPass = document.getElementById("setAdminPass").value.trim();

            const payloadData = {
                AdminWhatsapp: wa,
                Instagram: ig,
                TikTok: tik,
                Vouchers: vouchers,
                AdminUser: newAdminUser,
                AdminPass: newAdminPass
            };

            // Kirim base64 hasil kompresi instan baru jika di-upload, jika tidak kirim data lama
            payloadData.Logo = settingsFilesBase64.Logo || (globalSettings.Logo || "");
            payloadData.Banner = settingsFilesBase64.Banner || (globalSettings.Banner || "");
            payloadData.QRIS = settingsFilesBase64.QRIS || (globalSettings.QRIS || "");

            google.script.run
                .withSuccessHandler(function(response) {
                    hideLoader();
                    btn.disabled = false;
                    btn.innerHTML = `SIMPAN PENGATURAN TOKO <i data-lucide="check" class="w-4 h-4"></i>`;
                    lucide.createIcons();

                    if (response.success) {
                        showToast(response.message);
                        settingsFilesBase64 = {}; // Reset penampung
                        fetchSettings();
                    } else {
                        alert("Gagal menyimpan: " + response.message);
                    }
                })
                .withFailureHandler(function(err) {
                    hideLoader();
                    btn.disabled = false;
                    btn.innerHTML = `SIMPAN PENGATURAN TOKO <i data-lucide="check" class="w-4 h-4"></i>`;
                    lucide.createIcons();
                    alert("Error sistem: " + err.message);
                })
                .updateSettingsGAS(payloadData);
        }

        // =========================================================================
        // MESIN KOMPRESI GAMBAR CLIENT-SIDE DENGAN RESOLUSI DAN KUALITAS TINGGI (PREMIUM RETINA)
        // =========================================================================
        function compressAndConvertToBase64(file, maxWidth = 1600, maxHeight = 1600, quality = 0.85) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = function(event) {
                    const img = new Image();
                    img.onload = function() {
                        let width = img.width;
                        let height = img.height;

                        // Pertahankan Aspect Ratio yang Sempurna
                        if (width > height) {
                            if (width > maxWidth) {
                                height *= maxWidth / width;
                                width = maxWidth;
                            }
                        } else {
                            if (height > maxHeight) {
                                width *= maxHeight / height;
                                height = maxHeight;
                            }
                        }

                        const canvas = document.createElement('canvas');
                        canvas.width = width;
                        canvas.height = height;
                        const ctx = canvas.getContext('2d');
                        ctx.drawImage(img, 0, 0, width, height);

                        // Ekspor sebagai JPG dengan Kompresi Kustom (Optimal & Ringan)
                        const compressedBase64 = canvas.toDataURL('image/jpeg', quality);
                        resolve(compressedBase64);
                    };
                    img.onerror = function(err) { reject(err); };
                    img.src = event.target.result;
                };
                reader.onerror = function(err) { reject(err); };
                reader.readAsDataURL(file);
            });
        }

        // ============================================
        // FITUR BARU: MANAJEMEN DAN UPLOAD PRODUK AMAN
        // ============================================
        function buildPhotoUploaders() {
            const area = document.getElementById("photoUploadersArea");
            if (!area) return;
            area.innerHTML = "";
            for (let i = 1; i <= 10; i++) {
                const div = `
                    <div class="relative border-2 border-dashed border-gray-200 rounded-xl p-2 bg-lightGray hover:bg-gray-50 transition cursor-pointer flex flex-col items-center justify-center h-24 group overflow-hidden">
                        <input type="file" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer z-10" onchange="handleProductPhotoChange(this, ${i})">
                        <img id="prodFotoPreview${i}" class="absolute inset-0 w-full h-full object-cover hidden">
                        <div id="prodFotoPlaceholder${i}" class="flex flex-col items-center justify-center text-center space-y-1">
                            <i data-lucide="image-plus" class="w-5 h-5 text-gray-400 group-hover:scale-110 transition-transform"></i>
                            <span class="text-[9px] text-gray-400 font-bold uppercase">Foto ${i}</span>
                        </div>
                    </div>
                `;
                area.insertAdjacentHTML("beforeend", div);
            }
            if (typeof lucide !== "undefined") {
                lucide.createIcons();
            }
        }

        async function handleProductPhotoChange(input, index) {
            const file = input.files[0];
            if (!file) return;

            const placeholder = document.getElementById("prodFotoPlaceholder" + index);
            const originalHTML = placeholder.innerHTML;
            placeholder.innerHTML = `<span class="animate-spin rounded-full h-4 w-4 border-b-2 border-secondary"></span><p class="text-[8px] mt-1 text-gray-400">COMPRESS...</p>`;

            try {
                // Kompresi instan di memori browser dengan resolusi 1600px & Kualitas Premium 85%
                const compressedBase64 = await compressAndConvertToBase64(file, 1600, 1600, 0.85);
                
                const preview = document.getElementById("prodFotoPreview" + index);
                preview.src = compressedBase64;
                preview.classList.remove("hidden");
                placeholder.classList.add("hidden");
                
                // Simpan hasil kompresi berukuran super ringan (~100KB)
                productFilesBase64["Foto" + index] = compressedBase64;
            } catch (err) {
                console.error("Gagal kompresi foto:", err);
                showToast("Gagal memproses foto.");
                placeholder.innerHTML = originalHTML;
                lucide.createIcons();
            }
        }

        function adaptSizeOption(category) {
            const area = document.getElementById("sizeOptionsArea");
            if (!area) return;
            area.innerHTML = "";
            
            const sizes = (category === "SHOES") ? SHOE_SIZES : CLOTHING_SIZES;
            sizes.forEach(size => {
                const btn = `
                    <button type="button" onclick="toggleSizeSelect(this, '${size}')" class="size-opt-btn border border-gray-200 hover:border-secondary px-3 py-1.5 rounded-lg text-xs font-semibold text-gray-600 hover:text-secondary transition bg-white" data-size="${size}">
                        ${size}
                    </button>
                `;
                area.insertAdjacentHTML("beforeend", btn);
            });
        }

        function toggleSizeSelect(btn, size) {
            const idx = selectedProductSizes.indexOf(size);
            if (idx > -1) {
                selectedProductSizes.splice(idx, 1);
                btn.className = "size-opt-btn border border-gray-200 hover:border-secondary px-3 py-1.5 rounded-lg text-xs font-semibold text-gray-600 hover:text-secondary transition bg-white";
            } else {
                selectedProductSizes.push(size);
                btn.className = "size-opt-btn border-2 border-secondary px-3 py-1.5 rounded-lg text-xs font-bold text-secondary transition bg-secondary/5";
            }
        }

        function openProductModal() {
            document.getElementById("prodID").value = "";
            document.getElementById("productForm").reset();
            
            document.getElementById("prodNama").value = "";
            document.getElementById("prodHarga").value = "";
            document.getElementById("prodDiskon").value = "0";
            document.getElementById("prodStok").value = "";
            document.getElementById("prodKondisi").value = "";
            document.getElementById("prodDeskripsi").value = "";
            
            calculateFinalPrice();
            adaptSizeOption("TEE");
            selectedProductSizes = [];
            
            productFilesBase64 = {};
            for (let i = 1; i <= 10; i++) {
                const preview = document.getElementById("prodFotoPreview" + i);
                const placeholder = document.getElementById("prodFotoPlaceholder" + i);
                preview.src = "";
                preview.classList.add("hidden");
                placeholder.classList.remove("hidden");
            }

            document.getElementById("productModalTitle").textContent = "Tambah Produk Baru";
            document.getElementById("productModal").classList.remove("hidden");
        }

        function closeProductModal() {
            document.getElementById("productModal").classList.add("hidden");
        }

        function openEditProduct(id) {
            const product = globalProducts.find(p => {
                const norm = normalizeObjectKeys(p);
                return norm.id === id;
            });
            if (!product) return;
            const p = normalizeObjectKeys(product);

            document.getElementById("prodID").value = p.id;
            document.getElementById("prodNama").value = p.nama || "";
            document.getElementById("prodKategori").value = p.kategori || "TEE";
            document.getElementById("prodHarga").value = p.harga || "";
            document.getElementById("prodDiskon").value = p.diskon || "0";
            document.getElementById("prodStok").value = p.stok || "0";
            document.getElementById("prodKondisi").value = p.kondisi || "";
            document.getElementById("prodStatus").value = p.status || "AKTIF";
            document.getElementById("prodDeskripsi").value = p.deskripsi || "";
            
            calculateFinalPrice();
            adaptSizeOption(p.kategori || "TEE");

            selectedProductSizes = [];
            const sizesStr = p.ukuran || "";
            if (sizesStr) {
                selectedProductSizes = sizesStr.split(",").map(s => s.trim());
                document.querySelectorAll(".size-opt-btn").forEach(btn => {
                    const size = btn.getAttribute("data-size");
                    if (selectedProductSizes.includes(size)) {
                        btn.className = "size-opt-btn border-2 border-secondary px-3 py-1.5 rounded-lg text-xs font-bold text-secondary transition bg-secondary/5";
                    }
                });
            }

            productFilesBase64 = {};
            for (let i = 1; i <= 10; i++) {
                const preview = document.getElementById("prodFotoPreview" + i);
                const placeholder = document.getElementById("prodFotoPlaceholder" + i);
                const rawPhotoUrl = p["foto" + i];
                
                if (rawPhotoUrl) {
                    preview.src = toPublicDriveUrl(rawPhotoUrl);
                    preview.classList.remove("hidden");
                    placeholder.classList.add("hidden");
                } else {
                    preview.src = "";
                    preview.classList.add("hidden");
                    placeholder.classList.remove("hidden");
                }
            }

            document.getElementById("productModalTitle").textContent = "Edit Artikel Produk";
            document.getElementById("productModal").classList.remove("hidden");
        }

        async function handleProductSubmit(event) {
            event.preventDefault();
            
            const btn = document.getElementById("btnSubmitProduct");
            btn.disabled = true;
            btn.innerHTML = `<span class="animate-spin rounded-full h-4 w-4 border-b-2 border-white mr-2"></span> RINCIAN DISIMPAN...`;
            showLoader();

            const id = document.getElementById("prodID").value;
            const payload = {
                ID: id,
                Nama: document.getElementById("prodNama").value.trim(),
                Kategori: document.getElementById("prodKategori").value,
                Harga: parseFloat(document.getElementById("prodHarga").value) || 0,
                Diskon: parseFloat(document.getElementById("prodDiskon").value) || 0,
                Stok: parseInt(document.getElementById("prodStok").value) || 0,
                Ukuran: selectedProductSizes.join(", "),
                Kondisi: document.getElementById("prodKondisi").value.trim(),
                Status: document.getElementById("prodStatus").value,
                Deskripsi: document.getElementById("prodDeskripsi").value.trim()
            };

            const isEdit = id !== "";
            
            const successHandler = async function(response) {
                if (response.success) {
                    const productId = response.id || id;
                    
                    // Kumpulkan semua foto baru yang dipilih untuk diunggah secara asinkron berurutan (Sequential Upload)
                    const photoIndicesToUpload = [];
                    for (let i = 1; i <= 10; i++) {
                        if (productFilesBase64["Foto" + i]) {
                            photoIndicesToUpload.push(i);
                        }
                    }
                    
                    if (photoIndicesToUpload.length > 0) {
                        for (let step = 0; step < photoIndicesToUpload.length; step++) {
                            const idx = photoIndicesToUpload[step];
                            btn.innerHTML = `<span class="animate-spin rounded-full h-4 w-4 border-b-2 border-white mr-2"></span> UNGGAH FOTO ${step + 1}/${photoIndicesToUpload.length}...`;
                            
                            await new Promise((resolvePhoto, rejectPhoto) => {
                                google.script.run
                                    .withSuccessHandler(function(photoRes) {
                                        if (photoRes.success) {
                                            resolvePhoto();
                                        } else {
                                            console.error("Gagal unggah foto index: " + idx, photoRes.message);
                                            resolvePhoto(); // Lanjutkan mengunggah foto lainnya meskipun satu foto gagal
                                        }
                                    })
                                    .withFailureHandler(function(err) {
                                        console.error("Gagal koneksi server pada foto index: " + idx, err);
                                        resolvePhoto(); // Lanjutkan mengunggah foto lainnya
                                    })
                                    .uploadProductPhotoGAS(productId, idx, productFilesBase64["Foto" + idx]);
                            });
                        }
                    }
                    
                    hideLoader();
                    btn.disabled = false;
                    btn.innerHTML = `SIMPAN PRODUK <i data-lucide="save" class="w-4 h-4"></i>`;
                    lucide.createIcons();

                    showToast(isEdit ? "Katalog produk berhasil diperbarui!" : "Produk baru berhasil ditambahkan!");
                    closeProductModal();
                    fetchProductsList();
                    fetchStats();
                } else {
                    hideLoader();
                    btn.disabled = false;
                    btn.innerHTML = `SIMPAN PRODUK <i data-lucide="save" class="w-4 h-4"></i>`;
                    lucide.createIcons();
                    alert("Gagal menyimpan rincian produk: " + response.message);
                }
            };

            const failureHandler = function(err) {
                hideLoader();
                btn.disabled = false;
                btn.innerHTML = `SIMPAN PRODUK <i data-lucide="save" class="w-4 h-4"></i>`;
                lucide.createIcons();
                alert("Error sistem: " + err.message);
            };

            if (isEdit) {
                google.script.run
                    .withSuccessHandler(successHandler)
                    .withFailureHandler(failureHandler)
                    .updateProductGAS(payload);
            } else {
                google.script.run
                    .withSuccessHandler(successHandler)
                    .withFailureHandler(failureHandler)
                    .createProductGAS(payload);
            }
        }

        function archiveProduct(id) {
            if (!confirm("Apakah Anda yakin ingin menghapus produk ini dari database?")) return;
            showLoader();
            google.script.run
                .withSuccessHandler(function(response) {
                    hideLoader();
                    if (response.success) {
                        showToast(response.message);
                        fetchProductsList();
                        fetchStats();
                    } else {
                        alert("Gagal menghapus produk: " + response.message);
                    }
                })
                .withFailureHandler(function(err) {
                    hideLoader();
                    alert("Error sistem: " + err.message);
                })
                .deleteProductGAS(id);
        }

        function calculateFinalPrice() {
            const hg = parseFloat(document.getElementById("prodHarga").value) || 0;
            const dk = parseFloat(document.getElementById("prodDiskon").value) || 0;
            const fn = hg - (hg * (dk / 100));
            document.getElementById("prodHargaFinal").value = "Rp " + fn.toLocaleString("id-ID");
        }

        function showToast(msg) {
            const toast = document.getElementById("customToast");
            const toastMsg = document.getElementById("toastMessage");

            toastMsg.textContent = msg;
            toast.classList.remove("opacity-0", "translate-y-10", "pointer-events-none");
            
            setTimeout(() => {
                toast.classList.add("opacity-0", "translate-y-10", "pointer-events-none");
            }, 3000);
        }
    </script>
