<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PANGG.CASUALS - Admin Control Panel</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=300;400;500;600;700;800&family=Playfair+Display:ital,wght=0,400;0,700;1,400&display=swap" rel="stylesheet">
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons CDN -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#F7C948',    // Golden Yellow
                        secondary: '#1F4D3A',  // Dark Green Luxury
                        darkText: '#222222',   // Premium Dark Text
                        lightGray: '#F9F9F9',  // Clean BG
                    },
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                        serif: ['"Playfair Display"', 'serif'],
                    }
                }
            }
        }
    </script>
    <style>
        /* Custom scrollbar for beautiful lists */
        ::-webkit-scrollbar {
            width: 4px;
            height: 4px;
        }
        ::-webkit-scrollbar-track {
            background: #F1F1F1;
        }
        ::-webkit-scrollbar-thumb {
            background: #1F4D3A;
            border-radius: 2px;
        }
        /* Loader Overlay styling */
        .loader-overlay {
            background-color: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(2px);
        }
    </style>
</head>
<body class="bg-lightGray text-darkText font-sans selection:bg-secondary selection:text-white min-h-screen flex flex-col md:flex-row relative overflow-x-hidden">

    <!-- GLOBAL LOADING INDICATOR -->
    <div id="globalLoader" class="fixed inset-0 z-[100] flex items-center justify-center loader-overlay hidden">
        <div class="flex flex-col items-center gap-3 bg-white p-6 rounded-2xl shadow-xl border border-gray-100">
            <span class="animate-spin rounded-full h-10 w-10 border-b-2 border-secondary"></span>
            <p class="text-xs font-bold text-secondary tracking-wider uppercase">Menghubungkan ke Google Sheets...</p>
        </div>
    </div>

    <!-- LOGIN SCREEN OVERLAY -->
    <div id="loginScreen" class="fixed inset-0 z-50 bg-secondary flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl p-6 sm:p-10 w-full max-w-md space-y-6 border border-emerald-900/10 transform transition-all">
            <div class="text-center space-y-2">
                <!-- SATU WARNA HIJAU BOTOL -->
                <h2 class="font-serif text-3xl font-bold text-secondary">PANGG.CASUALS</h2>
                <p class="text-xs text-gray-400 tracking-wider uppercase font-semibold">Admin Panel Authentication</p>
                <div class="w-12 h-1 bg-primary mx-auto mt-2"></div>
            </div>
            
            <form id="loginForm" onsubmit="handleLoginSubmit(event)" class="space-y-4">
                <div>
                    <label class="block text-[10px] text-gray-500 font-bold uppercase mb-1">Username Admin</label>
                    <input type="text" id="loginUser" required placeholder="Masukkan username" class="w-full text-xs bg-lightGray border border-gray-200 px-4 py-3 rounded-xl focus:outline-none focus:border-secondary font-semibold">
                </div>
                <div>
                    <label class="block text-[10px] text-gray-500 font-bold uppercase mb-1">Password</label>
                    <input type="password" id="loginPass" required placeholder="Masukkan password" class="w-full text-xs bg-lightGray border border-gray-200 px-4 py-3 rounded-xl focus:outline-none focus:border-secondary font-semibold">
                </div>
                
                <button type="submit" id="btnLoginSubmit" class="w-full bg-secondary text-primary font-bold text-xs tracking-widest py-4 rounded-xl transition hover:opacity-95 uppercase flex items-center justify-center gap-2">
                    MASUK KE PANEL <i data-lucide="log-in" class="w-4 h-4"></i>
                </button>
            </form>
        </div>
    </div>

    <!-- MAIN DASHBOARD WRAPPER -->
    <div id="mainDashboardWrapper" class="flex-grow flex flex-col md:flex-row w-full hidden relative">
        
        <!-- MOBILE HEADER BAR -->
        <div class="md:hidden bg-secondary text-white px-4 py-3 flex items-center justify-between border-b border-emerald-900/40 sticky top-0 z-30 shadow-md">
            <div class="space-y-0.5">
                <h1 class="font-serif text-base font-bold tracking-tight text-primary">PANGG.CASUALS</h1>
                <p class="text-[9px] text-emerald-200 tracking-widest uppercase font-semibold">Control Panel</p>
            </div>
            <button onclick="toggleMobileSidebar()" class="p-2 text-emerald-100 hover:text-white rounded-lg hover:bg-emerald-800 transition">
                <i data-lucide="menu" id="mobileMenuIcon" class="w-6 h-6"></i>
            </button>
        </div>

        <!-- SIDEBAR BACKDROP IN MOBILE -->
        <div id="sidebarBackdrop" onclick="toggleMobileSidebar()" class="fixed inset-0 bg-black/60 z-40 hidden md:hidden transition-opacity"></div>

        <!-- SIDEBAR NAVIGATION DRAWER -->
        <aside id="adminSidebar" class="fixed inset-y-0 left-0 z-40 w-64 bg-secondary text-white shrink-0 flex flex-col justify-between border-r border-emerald-900/30 transform -translate-x-full transition-transform duration-300 md:translate-x-0 md:sticky md:top-0 md:h-screen md:z-20">
            <div>
                <!-- Sidebar Header (Desktop) -->
                <div class="p-6 border-b border-emerald-900/40 hidden md:flex items-center justify-between">
                    <div class="space-y-1">
                        <h1 class="font-serif text-lg font-bold tracking-tight text-primary">PANGG.CASUALS</h1>
                        <p class="text-[10px] text-emerald-200 tracking-widest uppercase font-semibold">Admin Panel</p>
                    </div>
                    <div class="w-8 h-8 rounded-lg bg-emerald-800 flex items-center justify-center text-primary">
                        <i data-lucide="shield-check" class="w-5 h-5"></i>
                    </div>
                </div>

                <!-- Nav Links -->
                <nav class="p-4 space-y-1.5 pt-10 md:pt-4">
                    <button onclick="switchTab('dashboard')" id="nav-dashboard" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-xs font-bold tracking-wider uppercase transition bg-primary text-secondary">
                        <i data-lucide="layout-dashboard" class="w-4 h-4"></i> DASHBOARD
                    </button>
                    <button onclick="switchTab('products')" id="nav-products" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-xs font-bold tracking-wider uppercase transition text-emerald-100 hover:bg-emerald-800/40">
                        <i data-lucide="package" class="w-4 h-4"></i> KELOLA PRODUK
                    </button>
                    <button onclick="switchTab('orders')" id="nav-orders" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-xs font-bold tracking-wider uppercase transition text-emerald-100 hover:bg-emerald-800/40">
                        <i data-lucide="shopping-cart" class="w-4 h-4"></i> KELOLA PESANAN
                    </button>
                    <button onclick="switchTab('settings')" id="nav-settings" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-xs font-bold tracking-wider uppercase transition text-emerald-100 hover:bg-emerald-800/40">
                        <i data-lucide="settings" class="w-4 h-4"></i> PENGATURAN TOKO
                    </button>
                </nav>
            </div>

            <!-- Logout & Footer Section -->
            <div class="p-4 border-t border-emerald-900/40 space-y-3 mb-16 md:mb-0">
                <button onclick="handleLogout()" class="w-full flex items-center justify-center gap-2 bg-red-600/20 text-red-400 hover:bg-red-600 hover:text-white px-4 py-2.5 rounded-lg text-xs font-bold tracking-wider uppercase transition">
                    <i data-lucide="log-out" class="w-4 h-4"></i> LOGOUT SESS
                </button>
                <div class="text-center text-[10px] text-emerald-200/60 font-light">
                    &copy; 2026 PANGG.CASUALS Store Engine.
                </div>
            </div>
        </aside>

        <!-- MAIN CONTENT CONTAINER -->
        <main class="flex-grow p-4 sm:p-8 overflow-y-auto max-w-7xl mx-auto w-full space-y-6">
            
            <!-- DASHBOARD STATS TAB -->
            <section id="tab-dashboard" class="tab-content space-y-6">
                <div class="flex justify-between items-center border-b border-gray-200 pb-4">
                    <div>
                        <h2 class="font-serif text-2xl sm:text-3xl font-bold text-secondary">Realtime Overview</h2>
                        <p class="text-[11px] sm:text-xs text-gray-500 mt-0.5">Pantau performa produk dan penjualan PANGG.CASUALS Anda.</p>
                    </div>
                    <button onclick="fetchStats()" class="p-2.5 bg-white border border-gray-200 rounded-xl text-secondary hover:bg-gray-50 transition shadow-sm" title="Refresh Data">
                        <i data-lucide="rotate-cw" class="w-4 h-4"></i>
                    </button>
                </div>

                <!-- Stats Grid -->
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6">
                    <!-- Total Produk -->
                    <div class="bg-white p-4 sm:p-6 rounded-2xl border border-gray-100 shadow-sm flex items-center justify-between">
                        <div class="space-y-1">
                            <span class="text-[9px] sm:text-[10px] text-gray-400 font-bold tracking-wider uppercase">Total Produk</span>
                            <p id="statTotalProducts" class="text-xl sm:text-3xl font-extrabold text-secondary">0</p>
                        </div>
                        <div class="w-8 h-8 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl bg-secondary/5 text-secondary flex items-center justify-center">
                            <i data-lucide="box" class="w-4 h-4 sm:w-6 sm:h-6"></i>
                        </div>
                    </div>
                    <!-- Total Order -->
                    <div class="bg-white p-4 sm:p-6 rounded-2xl border border-gray-100 shadow-sm flex items-center justify-between">
                        <div class="space-y-1">
                            <span class="text-[9px] sm:text-[10px] text-gray-400 font-bold tracking-wider uppercase">Total Order</span>
                            <p id="statTotalOrders" class="text-xl sm:text-3xl font-extrabold text-secondary">0</p>
                        </div>
                        <div class="w-8 h-8 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl bg-primary/10 text-secondary flex items-center justify-center">
                            <i data-lucide="shopping-bag" class="w-4 h-4 sm:w-6 sm:h-6 text-yellow-600"></i>
                        </div>
                    </div>
                    <!-- Pending Order -->
                    <div class="bg-white p-4 sm:p-6 rounded-2xl border border-gray-100 shadow-sm flex items-center justify-between">
                        <div class="space-y-1">
                            <span class="text-[9px] sm:text-[10px] text-gray-400 font-bold tracking-wider uppercase">Pending Order</span>
                            <p id="statPendingOrders" class="text-xl sm:text-3xl font-extrabold text-red-600">0</p>
                        </div>
                        <div class="w-8 h-8 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl bg-red-50 text-red-600 flex items-center justify-center">
                            <i data-lucide="clock" class="w-4 h-4 sm:w-6 sm:h-6"></i>
                        </div>
                    </div>
                    <!-- Sold Out -->
                    <div class="bg-white p-4 sm:p-6 rounded-2xl border border-gray-100 shadow-sm flex items-center justify-between">
                        <div class="space-y-1">
                            <span class="text-[9px] sm:text-[10px] text-gray-400 font-bold tracking-wider uppercase">Stok Habis</span>
                            <p id="statSoldOut" class="text-xl sm:text-3xl font-extrabold text-amber-600">0</p>
                        </div>
                        <div class="w-8 h-8 sm:w-12 sm:h-12 rounded-lg sm:rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center">
                            <i data-lucide="package-x" class="w-4 h-4 sm:w-6 sm:h-6"></i>
                        </div>
                    </div>
                </div>

                <!-- CONNECTION DIAGNOSTICS CARD -->
                <div class="bg-white p-4 sm:p-6 rounded-2xl border border-gray-100 shadow-sm space-y-4">
                    <div class="flex items-center justify-between">
                        <h3 class="font-serif text-xs sm:text-sm font-bold text-secondary flex items-center gap-2">
                            <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></span> 
                            Integrasi Database Google Sheets
                        </h3>
                        <span id="diagnosticStatusText" class="text-[8px] sm:text-[9px] bg-emerald-50 text-emerald-600 font-bold px-2.5 py-1 rounded-full border border-emerald-100 uppercase tracking-widest">Connected</span>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-xs">
                        <div class="bg-lightGray p-4 rounded-xl space-y-1">
                            <span class="text-gray-400 block text-[9px] sm:text-[10px] font-bold uppercase tracking-wider">Nama Google Sheet Aktif</span>
                            <p id="diagSheetName" class="font-bold text-secondary truncate">Memuat informasi...</p>
                        </div>
                        <div class="bg-lightGray p-4 rounded-xl space-y-1 flex flex-col justify-center">
                            <span class="text-gray-400 block text-[9px] sm:text-[10px] font-bold uppercase tracking-wider mb-1">Aksi Cepat Database</span>
                            <a id="diagSheetUrl" href="#" target="_blank" class="font-bold text-emerald-700 hover:underline inline-flex items-center gap-1">
                                Buka Google Sheet Database <i data-lucide="external-link" class="w-3.5 h-3.5"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- CATEGORY STOCK DISTRIBUTION BAR CHART -->
                <div class="bg-white p-4 sm:p-6 rounded-2xl border border-gray-100 shadow-sm space-y-4">
                    <h3 class="font-serif text-base sm:text-lg font-bold text-secondary">Distribusi Stok per Kategori</h3>
                    <div id="categoryStockDistributionArea" class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-xs font-semibold">
                        <div class="bg-lightGray p-4 rounded-xl flex flex-col justify-center items-center text-gray-400">
                            <p>Memproses visualisasi data stok...</p>
                        </div>
                    </div>
                </div>

                <!-- Quick Action Shortcuts -->
                <div class="bg-white p-4 sm:p-6 rounded-2xl border border-gray-100 shadow-sm space-y-4">
                    <h3 class="font-serif text-base sm:text-lg font-bold text-secondary">Akses Cepat Pengelolaan</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                        <button onclick="switchTab('products'); openProductModal();" class="flex items-center gap-3 p-4 bg-lightGray rounded-xl hover:bg-secondary/5 border border-gray-100 transition group text-left">
                            <div class="w-10 h-10 rounded-lg bg-secondary text-primary flex items-center justify-center shrink-0">
                                <i data-lucide="plus-circle" class="w-5 h-5"></i>
                            </div>
                            <div>
                                <p class="text-xs font-bold text-secondary">Tambah Produk</p>
                                <p class="text-[10px] text-gray-400">Unggah foto & size baru</p>
                            </div>
                        </button>
                        <button onclick="switchTab('orders')" class="flex items-center gap-3 p-4 bg-lightGray rounded-xl hover:bg-secondary/5 border border-gray-100 transition group text-left">
                            <div class="w-10 h-10 rounded-lg bg-primary text-secondary flex items-center justify-center shrink-0">
                                <i data-lucide="eye" class="w-5 h-5"></i>
                            </div>
                            <div>
                                <p class="text-xs font-bold text-secondary">Lihat Order Masuk</p>
                                <p class="text-[10px] text-gray-400">Verifikasi bukti transfer</p>
                            </div>
                        </button>
                        <button onclick="switchTab('settings')" class="flex items-center gap-3 p-4 bg-lightGray rounded-xl hover:bg-secondary/5 border border-gray-100 transition group text-left">
                            <div class="w-10 h-10 rounded-lg bg-gray-200 text-secondary flex items-center justify-center shrink-0">
                                <i data-lucide="sliders" class="w-5 h-5"></i>
                            </div>
                            <div>
                                <p class="text-xs font-bold text-secondary">Pengaturan Store</p>
                                <p class="text-[10px] text-gray-400">Ubah QRIS, Logo, & Voucher</p>
                            </div>
                        </button>
                    </div>
                </div>
            </section>

            <!-- KELOLA PRODUK TAB -->
            <section id="tab-products" class="tab-content space-y-6 hidden">
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-gray-200 pb-4">
                    <div>
                        <h2 class="font-serif text-2xl sm:text-3xl font-bold text-secondary">Kelola Produk Toko</h2>
                        <p class="text-xs text-gray-500 mt-0.5">Tambah, edit informasi, and arsipkan katalog produk aktif.</p>
                    </div>
                    <button onclick="openProductModal()" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-secondary text-primary font-bold text-xs tracking-wider uppercase px-5 py-3.5 rounded-xl shadow-lg transition hover:opacity-95">
                        <i data-lucide="plus" class="w-4 h-4"></i> TAMBAH PRODUK BARU
                    </button>
                </div>

                <!-- Search and Category Filter for Products -->
                <div class="flex flex-col sm:flex-row gap-3 bg-white p-4 rounded-xl border border-gray-100 shadow-sm justify-between items-center">
                    <div class="relative w-full sm:w-72">
                        <i data-lucide="search" class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 transform -translate-y-1/2"></i>
                        <input type="text" id="adminProductSearch" oninput="filterAdminProducts()" placeholder="Cari nama artikel..." class="w-full text-xs bg-lightGray border border-transparent focus:border-secondary pl-9 pr-3 py-2.5 rounded-lg focus:outline-none">
                    </div>
                    <div class="flex items-center gap-2 text-xs w-full sm:w-auto">
                        <span class="text-gray-400 font-bold">Kategori:</span>
                        <select id="adminProductCategoryFilter" onchange="filterAdminProducts()" class="bg-lightGray border-0 text-secondary font-bold text-xs py-2 px-3 rounded-lg focus:outline-none">
                            <option value="ALL">Semua Kategori</option>
                            <option value="TEE">TEE</option>
                            <option value="HOODIE">HOODIE</option>
                            <option value="OVERSHIRT">OVERSHIRT</option>
                            <option value="CREWNECK">CREWNECK</option>
                            <option value="JACKET">JACKET</option>
                            <option value="PANTS">PANTS</option>
                            <option value="HAT">HAT</option>
                            <option value="SHOES">SHOES</option>
                        </select>
                    </div>
                </div>

                <!-- Product List Area -->
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                    <div class="overflow-x-auto w-full">
                        <table class="w-full text-left border-collapse min-w-[750px]">
                            <thead>
                                <tr class="bg-lightGray border-b border-gray-100 text-[10px] text-gray-400 font-bold uppercase tracking-wider">
                                    <th class="p-4">Produk</th>
                                    <th class="p-4">Kategori</th>
                                    <th class="p-4">Harga (Final)</th>
                                    <th class="p-4 text-center">Ukuran</th>
                                    <th class="p-4 text-center">Stok</th>
                                    <th class="p-4 text-center">Status</th>
                                    <th class="p-4 text-center">Aksi</th>
                                </tr>
                            </thead>
                            <tbody id="tblProductBody" class="divide-y divide-gray-100 text-xs text-secondary font-medium">
                                <!-- Diisi dinamis oleh Javascript -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <!-- KELOLA PESANAN TAB -->
            <section id="tab-orders" class="tab-content space-y-6 hidden">
                <div class="border-b border-gray-200 pb-4">
                    <h2 class="font-serif text-2xl sm:text-3xl font-bold text-secondary">Kelola Pesanan Masuk</h2>
                    <p class="text-xs text-gray-500 mt-0.5">Kelola transaksi pembelian, konfirmasi pembayaran QRIS, dan status pemrosesan paket.</p>
                </div>

                <!-- Search and Status Filter for Orders -->
                <div class="flex flex-col sm:flex-row gap-3 bg-white p-4 rounded-xl border border-gray-100 shadow-sm justify-between items-center">
                    <div class="relative w-full sm:w-72">
                        <i data-lucide="search" class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 transform -translate-y-1/2"></i>
                        <input type="text" id="adminOrderSearch" oninput="filterAdminOrders()" placeholder="Cari nama, Order ID, WA..." class="w-full text-xs bg-lightGray border border-transparent focus:border-secondary pl-9 pr-3 py-2.5 rounded-lg focus:outline-none">
                    </div>
                    <div class="flex items-center gap-2 text-xs w-full sm:w-auto">
                        <span class="text-gray-400 font-bold">Status:</span>
                        <select id="adminOrderStatusFilter" onchange="filterAdminOrders()" class="bg-lightGray border-0 text-secondary font-bold text-xs py-2 px-3 rounded-lg focus:outline-none">
                            <option value="ALL">Semua Status</option>
                            <option value="MENUNGGU PEMBAYARAN">MENUNGGU PEMBAYARAN</option>
                            <option value="MENUNGGU VERIFIKASI">MENUNGGU VERIFIKASI</option>
                            <option value="DIPROSES">DIPROSES</option>
                            <option value="DIKIRIM">DIKIRIM</option>
                            <option value="SELESAI">SELESAI</option>
                            <option value="DIBATALKAN">DIBATALKAN</option>
                        </select>
                    </div>
                </div>

                <!-- Orders Table Area -->
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                    <div class="overflow-x-auto w-full">
                        <table class="w-full text-left border-collapse min-w-[950px]">
                            <thead>
                                <tr class="bg-lightGray border-b border-gray-100 text-[10px] text-gray-400 font-bold uppercase tracking-wider">
                                    <th class="p-4">Order ID / Tanggal</th>
                                    <th class="p-4">Pembeli</th>
                                    <th class="p-4">Detail Produk</th>
                                    <th class="p-4 text-right">Total Tagihan</th>
                                    <th class="p-4 text-center">Bukti Transfer</th>
                                    <th class="p-4 text-center">Status</th>
                                    <th class="p-4 text-center">Aksi</th>
                                </tr>
                            </thead>
                            <tbody id="tblOrdersBody" class="divide-y divide-gray-100 text-xs text-secondary font-medium">
                                <!-- Diisi dinamis oleh Javascript -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <!-- CONFIG / SETTINGS TAB -->
            <section id="tab-settings" class="tab-content space-y-6 hidden">
                <div class="border-b border-gray-200 pb-4">
                    <h2 class="font-serif text-2xl sm:text-3xl font-bold text-secondary">Pengaturan Storefront</h2>
                    <p class="text-xs text-gray-500 mt-0.5">Ubah identitas visual brand, QRIS merchant pembayaran, kredensial login, dan tautan sosial media toko Anda.</p>
                </div>

                <!-- Settings Form Grid (KEMBALI PAKAI INPUT FILE DENGAN TEKNOLOGI CLIENT-SIDE COMPRESSION ANTI-ERRORS 50K) -->
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 sm:p-8 max-w-3xl">
                    <form id="settingsForm" onsubmit="saveStoreSettings(event)" class="space-y-6">
                        
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                            <!-- Logo Brand via File -->
                            <div class="space-y-2">
                                <label class="block text-xs font-bold tracking-wider text-secondary uppercase">Logo Brand</label>
                                <div class="flex items-center gap-4">
                                    <div class="w-16 h-16 border border-gray-200 rounded-lg overflow-hidden flex items-center justify-center bg-lightGray shrink-0">
                                        <img id="logoSettingPreview" src="https://images.unsplash.com/photo-1595079676339-1534801ad6cf?auto=format&fit=crop&q=80&w=200" alt="Logo Preview" class="max-w-full max-h-full object-contain" onerror="this.src='https://placehold.co/200?text=PANGG'">
                                    </div>
                                    <div class="flex-1">
