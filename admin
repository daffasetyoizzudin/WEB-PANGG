        function followUpCustomer(orderId) {
            const orderRaw = globalOrders.find(item => {
                const norm = normalizeObjectKeys(item);
                return (norm.orderid || norm.id) === orderId;
            });
            if (!orderRaw) return;

            const order = normalizeObjectKeys(orderRaw);

            let msg = "";
            if (order.status === "MENUNGGU PEMBAYARAN" || order.status === "PENDING") {
                msg = `Halo Kak ${order.namapembeli},\n\nTerima kasih telah memesan di PANGG.CASUALS.\n\nKami mengonfirmasi pesanan Kakak dengan ID: *${order.orderid || order.id}* sebesar *Rp ${parseFloat(order.total).toLocaleString('id-ID')}* masih menunggu pembayaran.\n\nApakah ada yang bisa kami bantu dalam proses transaksinya?`;
            } else if (order.status === "DIPROSES") {
                msg = `Halo Kak ${order.namapembeli},\n\nPembayaran Kakak untuk ID: *${order.orderid || order.id}* telah kami terima dan verifikasi.\n\nSaat ini paket Kakak sedang diproses pengemasan dengan standar premium kami.\n\nMohon ditunggu ya!`;
            } else if (order.status === "DIKIRIM") {
                msg = `Halo Kak ${order.namapembeli},\n\nKabar gembira! Pesanan Kakak dengan ID: *${order.orderid || order.id}* telah dikirim hari ini.\n\nTerima kasih banyak telah berbelanja di PANGG.CASUALS ✨`;
            } else {
                msg = `Halo Kak ${order.namapembeli},\n\nMenghubungi terkait transaksi pesanan Kakak di PANGG.CASUALS dengan ID: *${order.orderid || order.id}* status saat ini: *${order.status}*.\n\nJika ada pertanyaan jangan ragu hubungi kami kembali.`;
            }

            const waLink = `https://api.whatsapp.com/send?phone=${order.whatsapp.replace(/\D/g, '')}&text=${encodeURIComponent(msg)}`;
            window.open(waLink, "_blank");
        }

