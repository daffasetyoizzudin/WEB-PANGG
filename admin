        function renderCategoryStockChart() {
            const area = document.getElementById("categoryStockDistributionArea");
            area.innerHTML = "";
            
            const catMap = {};
            globalProducts.forEach(item => {
                const norm = normalizeObjectKeys(item);
                const cat = (norm.kategori || "TEE").toUpperCase();
                const stok = parseInt(norm.stok) || 0;
                catMap[cat] = (catMap[cat] || 0) + stok;
            });
            
            const categories = Object.keys(catMap);
            if (categories.length === 0) {
                area.innerHTML = `<p class="text-center text-gray-400 col-span-2 py-4">Belum ada data stok produk.</p>`;
                return;
            }
            
            const maxStok = Math.max(...Object.values(catMap), 1);
            
            categories.forEach(cat => {
                const stok = catMap[cat];
                const pct = (stok / maxStok) * 100;
                const barHtml = `
                    <div class="bg-lightGray p-4 rounded-xl space-y-2">
                        <div class="flex justify-between text-[11px]">
                            <span class="text-secondary font-bold">${cat}</span>
                            <span class="text-gray-400">${stok} Pcs</span>
                        </div>
                        <div class="w-full bg-gray-200 rounded-full h-2">
                            <div class="bg-secondary h-2 rounded-full transition-all duration-1000" style="width: ${pct}%"></div>
                        </div>
                    </div>
                `;
                area.insertAdjacentHTML("beforeend", barHtml);
            });
        }

